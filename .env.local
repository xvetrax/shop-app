# Opay Configuration
OPAY_MERCHANT_ID=your_merchant_id
OPAY_API_KEY=your_api_key
OPAY_API_URL=https://api.opay.lt
# For testing, use sandbox URL: https://sandbox.opay.lt/api

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production: https://yourdomain.com

# Opay Callback URL (webhook)
OPAY_CALLBACK_URL=http://localhost:3000/api/opay-callback
# For production: https://yourdomain.com/api/opay-callback

# Opay Return URLs (after payment)
OPAY_SUCCESS_URL=http://localhost:3000/order/success
OPAY_FAILURE_URL=http://localhost:3000/order/failure
# For production: https://yourdomain.com/order/success and /order/failure
